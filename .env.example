# SoftwareHub Environment Configuration for Manual Services
# Copy this to .env in your root directory and each service directory

# ===========================================
# SUPABASE (Primary — replaces self-hosted Postgres)
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_ANON_KEY=your-legacy-anon-jwt
SUPABASE_SERVICE_KEY=sb_secret_...
# Database password (Dashboard → Settings → Database — separate from API secret)
SUPABASE_DB_PASSWORD=your-database-password
# Or full connection string:
# DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres

# ===========================================
# LEGACY DATABASE (optional — local dev fallback)
# ===========================================
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://admin:password@localhost:27017/softwarehub-chat?authSource=admin

# ===========================================
# SERVICE CONFIGURATION
# ===========================================
NODE_ENV=development
SITE_URL=https://yourdomain.com
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
SUPABASE_STORAGE_BUCKET=uploads
SESSION_SECRET=your-super-secret-session-key
JWT_SECRET=your-jwt-secret

# Service URLs (for inter-service communication)
EMAIL_SERVICE_URL=http://localhost:3001
CHAT_SERVICE_URL=http://localhost:3002
NOTIFICATION_SERVICE_URL=http://localhost:3003

# ===========================================
# EMAIL SERVICE (SendGrid)
# ===========================================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key

# ===========================================
# FIREBASE PUSH NOTIFICATIONS
# ===========================================
FCM_VAPID_KEY=your-fcm-vapid-key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY=your-firebase-private-key

# ===========================================
# CLOUDFLARE R2 STORAGE
# ===========================================
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key
CLOUDFLARE_R2_BUCKET_NAME=your-r2-bucket
CLOUDFLARE_R2_ENDPOINT=your-r2-endpoint

# ===========================================
# PAYMENT — payOS (https://payos.vn/docs/)
# ===========================================
PAYOS_CLIENT_ID=your-client-id
PAYOS_API_KEY=your-api-key
PAYOS_CHECKSUM_KEY=your-checksum-key
PAYOS_WEBHOOK_URL=https://your-domain.com/api/payment/webhook

# ===========================================
# DEEPSEEK AI (blog admin AI rewrite)
# ===========================================
DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ===========================================
# GA4 Data API (optional — embed traffic in /admin/analytics)
# ===========================================
GA4_PROPERTY_ID=123456789
GA4_CLIENT_EMAIL=analytics-viewer@project.iam.gserviceaccount.com
GA4_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ===========================================
# SERVICE PORTS
# ===========================================
PORT=5000
EMAIL_SERVICE_PORT=3001
CHAT_SERVICE_PORT=3002
NOTIFICATION_SERVICE_PORT=3003