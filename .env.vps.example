# Copy to /var/www/software-hub/.env on VPS (NEVER commit)
# cp .env.vps.example .env && nano .env

NODE_ENV=production
PORT=5000
SITE_URL=https://swhubco.com

# Supabase (Dashboard → Settings → API + Database)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_ANON_KEY=eyJ...legacy-anon-if-needed
SUPABASE_SERVICE_KEY=sb_secret_...
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
SUPABASE_DB_PORT=6543

# Build-time vars (also set in GitHub Actions secrets for CI build)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Redis / Mongo (docker-compose.vps.yml on same VPS)
REDIS_URL=redis://:password@127.0.0.1:6379
REDIS_PASSWORD=password
MONGODB_URL=mongodb://admin:password@127.0.0.1:27017/softwarehub-chat?authSource=admin

# Microservices (PM2 ecosystem.config.cjs)
EMAIL_SERVICE_URL=http://127.0.0.1:3001
CHAT_SERVICE_URL=http://127.0.0.1:3002
NOTIFICATION_SERVICE_URL=http://127.0.0.1:3003

# Optional integrations
SENDGRID_API_KEY=
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_WEBHOOK_URL=https://swhubco.com/api/payment/webhook
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
VITE_GA_MEASUREMENT_ID=
