# Production Environment Variables for Docker
# Copy this file to .env.production and update with your actual values

# ============================================
# Database Configuration
# ============================================
DB_NAME=software_hub
DB_USER=software_hub_user
DB_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD

# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
PORT=3000

# Session Secret - Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_THIS_TO_RANDOM_SECRET

# ============================================
# Email Service (Resend)
# ============================================
RESEND_API_KEY=

# ============================================
# OAuth Providers (Optional)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ============================================
# Chat Service
# ============================================
CHAT_SERVICE_URL=http://chat-service:3001

# ============================================
# External URLs (if needed)
# ============================================
# FRONTEND_URL=http://95.111.253.111
# API_URL=http://95.111.253.111/api
