# VPS Production Environment Variables Template
# Copy this to .env.production and fill in the values

# ============================================
# Database Configuration (Docker Containers)
# ============================================

# PostgreSQL
POSTGRES_DB=softwarehub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD_32_CHARS
DATABASE_URL=postgresql://postgres:CHANGE_ME_SECURE_PASSWORD_32_CHARS@localhost:5432/softwarehub

# MongoDB
MONGO_INITDB_DATABASE=softwarehub-chat
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_SECURE_PASSWORD_32_CHARS
MONGODB_URL=mongodb://admin:CHANGE_ME_SECURE_PASSWORD_32_CHARS@localhost:27017/softwarehub-chat?authSource=admin

# Redis
REDIS_PASSWORD=CHANGE_ME_SECURE_PASSWORD_32_CHARS
REDIS_URL=redis://:CHANGE_ME_SECURE_PASSWORD_32_CHARS@localhost:6379

# ============================================
# Application Configuration
# ============================================

NODE_ENV=production
PORT=3000
SESSION_SECRET=CHANGE_ME_RANDOM_STRING_MIN_48_CHARS
JWT_SECRET=CHANGE_ME_RANDOM_STRING_MIN_48_CHARS

# ============================================
# Microservice URLs (localhost - PM2 managed)
# ============================================

EMAIL_SERVICE_URL=http://localhost:3001
CHAT_SERVICE_URL=http://localhost:3002
NOTIFICATION_SERVICE_URL=http://localhost:3003

# ============================================
# Email Service (SendGrid)
# ============================================

SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Or use SMTP
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key_here

# ============================================
# Firebase (Push Notifications)
# ============================================

FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email@your_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FCM_VAPID_KEY=your_vapid_key

# ============================================
# Storage (Cloudflare R2 or AWS S3)
# ============================================

# Cloudflare R2
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=your_bucket_name
CLOUDFLARE_R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# Or AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name

# ============================================
# Payment (Stripe)
# ============================================

STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# OAuth (Optional)
# ============================================

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ============================================
# Other Services
# ============================================

# Resend (Alternative to SendGrid)
RESEND_API_KEY=your_resend_api_key

# Client URL (for CORS and redirects)
CLIENT_URL=http://95.111.253.111

# API URL
API_URL=http://95.111.253.111/api
