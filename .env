# Database Configuration for Manual Services (Docker databases)
DATABASE_URL=postgresql://postgres:password@localhost:5432/softwarehub
POSTGRES_DB=softwarehub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Application Configuration
NODE_ENV=development
PORT=5000
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Development Mode - Authentication Bypass (ONLY FOR DEVELOPMENT!)
# Set to "true" to disable authentication and auto-login as mock user
# Set to "false" or remove to enable normal authentication
DISABLE_AUTH=false
MOCK_USER_ID=2
MOCK_USER_ROLE=seller

